<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/carDetailsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="18dp"
        android:paddingBottom="20dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_home_chip"
                    android:clickable="true"
                    android:contentDescription="Назад"
                    android:focusable="true"
                    android:padding="10dp"
                    android:src="@drawable/ic_arrow_back_24"
                    android:tint="@color/home_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Карточка автомобиля"
                    android:textColor="@color/home_text_primary"
                    android:textSize="23sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDeleteCar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="Удалить автомобиль"
                    android:minHeight="40dp"
                    android:minWidth="40dp"
                    android:text=""
                    app:backgroundTint="@color/home_surface"
                    app:cornerRadius="20dp"
                    app:icon="@drawable/ic_trash_24"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="18dp"
                    app:iconTint="@color/home_danger"
                    app:rippleColor="@color/home_surface_soft"
                    app:strokeColor="@color/home_stroke"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_home_summary_card"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/tvCarDetailsTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="@color/home_text_inverse"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCarDetailsMeta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:alpha="0.9"
                        android:text="Пробег: -"
                        android:textColor="@color/home_text_inverse"
                        android:textSize="13sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdateMileage"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="Обновить пробег"
                android:textAllCaps="false"
                android:textColor="@color/home_text_inverse"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/home_primary"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_directions"
                app:iconGravity="textStart"
                app:iconPadding="10dp"
                app:iconTint="@color/home_text_inverse"
                app:rippleColor="@color/home_surface_soft" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_horizontal"
                android:text="Раз в неделю обновляйте актуальный пробег автомобиля."
                android:textColor="@color/home_text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenServiceHistory"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="История обслуживания"
                android:textAllCaps="false"
                android:textColor="@color/home_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@color/home_surface"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_arrow_forward_24"
                app:iconGravity="textEnd"
                app:iconPadding="8dp"
                app:iconTint="@color/home_text_secondary"
                app:rippleColor="@color/home_surface_soft"
                app:strokeColor="@color/home_stroke"
                app:strokeWidth="1dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Расходники и запчасти"
                    android:textColor="@color/home_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddPart"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minHeight="40dp"
                    android:minWidth="0dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="14dp"
                    android:text="Добавить"
                    android:textAllCaps="false"
                    android:textColor="@color/home_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/home_surface"
                    app:cornerRadius="20dp"
                    app:icon="@android:drawable/ic_input_add"
                    app:iconGravity="textStart"
                    app:iconPadding="5dp"
                    app:iconSize="16dp"
                    app:iconTint="@color/home_primary"
                    app:rippleColor="@color/home_surface_soft"
                    app:strokeColor="@color/home_stroke"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvPartsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Пока нет добавленных расходников или запчастей."
                android:textColor="@color/home_text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/partsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
