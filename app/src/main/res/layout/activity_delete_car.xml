<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/deleteCarRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="18dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnDeleteCarBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_home_chip"
                    android:clickable="true"
                    android:contentDescription="Назад"
                    android:focusable="true"
                    android:padding="10dp"
                    android:src="@drawable/ic_arrow_back_24"
                    android:tint="@color/home_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Удаление автомобиля"
                    android:textColor="@color/home_text_primary"
                    android:textSize="23sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_home_summary_card"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Опасное действие"
                        android:textColor="@color/home_text_inverse"
                        android:textSize="19sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:alpha="0.92"
                        android:text="Удаление автомобиля уберёт его из списка и связанных экранов."
                        android:textColor="@color/home_text_inverse"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/home_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/home_danger"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvDeleteCarTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Volkswagen Polo"
                        android:textColor="@color/home_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDeleteCarMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="A123BC 777 • 2018 • 128 450 км"
                        android:textColor="@color/home_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Перед удалением убедитесь, что данные автомобиля больше не нужны."
                        android:textColor="@color/home_danger"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCancelDeleteCar"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:text="Отмена"
                            android:textAllCaps="false"
                            android:textColor="@color/home_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/home_surface"
                            app:cornerRadius="16dp"
                            app:rippleColor="@color/home_surface_soft"
                            app:strokeColor="@color/home_stroke"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnConfirmDeleteCar"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:text="Удалить"
                            android:textAllCaps="false"
                            android:textColor="@color/home_text_inverse"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/home_danger"
                            app:cornerRadius="16dp"
                            app:icon="@android:drawable/ic_menu_delete"
                            app:iconGravity="textStart"
                            app:iconPadding="8dp"
                            app:iconTint="@color/home_text_inverse"
                            app:rippleColor="@color/home_surface_soft" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>



