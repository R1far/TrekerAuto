<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".app.TrekerAutoApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TrekerAutoApp">
        <activity
            android:name=".screen.DeleteCarActivity"
            android:exported="false" />
        <activity
            android:name=".screen.ReminderSettingsActivity"
            android:exported="false" />
        <activity
            android:name=".screen.UpdateMileageActivity"
            android:exported="false" />
        <activity
            android:name=".screen.EditPartActivity"
            android:exported="false" />
        <activity
            android:name=".screen.AddServiceActivity"
            android:exported="false" />
        <activity
            android:name=".screen.AddPartActivity"
            android:exported="false" />
        <activity
            android:name=".screen.ServiceHistoryActivity"
            android:exported="false" />
        <activity
            android:name=".screen.AddCarActivity"
            android:exported="false" />
        <activity
            android:name=".screen.CarDetailsActivity"
            android:exported="false" />
        <activity
            android:name=".screen.HomeActivity"
            android:exported="false" />
        <activity
            android:name=".screen.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".screen.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>

